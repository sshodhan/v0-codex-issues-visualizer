# Copy to .env and fill in. If DATABASE_URL is blank the API serves the
# canonical seed dataset (backend/app/seed_data.py) — useful for local dev
# and for keeping the frontend working without Supabase.

# asyncpg-compatible Postgres URL. For Supabase use the direct connection
# string (port 5432), not the REST URL. Example:
# postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# Redis for response caching. Leave blank to disable caching.
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# Comma-separated list of frontend origins permitted by CORS.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

ENVIRONMENT=development
RATE_LIMIT_DEFAULT=60/minute
